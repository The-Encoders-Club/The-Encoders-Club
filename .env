# ============================================================
# Cloudflare D1 — the DATABASE_URL is used by Prisma CLI only
# for schema introspection / generate. At runtime the D1 binding
# is injected by Cloudflare via wrangler.toml.
#
# For local Prisma operations (generate, etc.) use a local SQLite file:
# ============================================================
DATABASE_URL=file:./dev.db

# Node environment
NODE_ENV=development
