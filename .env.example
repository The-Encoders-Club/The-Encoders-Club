# Base de datos D1 en Cloudflare
# Para desarrollo local, usa SQLite
DATABASE_URL=file:./prisma/dev.db

# Autenticación y sesiones
NEXTAUTH_SECRET=tu-secret-aqui
NEXTAUTH_URL=https://tu-dominio.com

# Discord (opcional)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=
DISCORD_WEBHOOK_URL=

# Ko-fi (para donaciones)
KOFI_API_KEY=

# Otros
NODE_ENV=production
