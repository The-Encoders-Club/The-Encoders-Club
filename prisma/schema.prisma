generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ USER SYSTEM ============

model User {
  id            String    @id @default(cuid())
  nickname      String    @unique
  email         String?   @unique
  passwordHash  String
  avatar        String?   @default("/default-avatar.png")
  role          String    @default("user") // user, collaborator, moderator, admin, owner
  isPremium     Boolean   @default(false)
  isBanned      Boolean   @default(false)
  banReason     String?
  discordId     String?   @unique
  discordLinked Boolean   @default(false)
  locale        String    @default("es") // es, en
  rememberToken String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  comments      Comment[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  reactions     Reaction[]
  donations     Donation[]
}

// ============ COMMENTS ============

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  parentId  String?
  targetId  String   // project ID or news ID
  targetType String  // "project" or "news"
  isDeleted Boolean  @default(false)
  isReported Boolean @default(false)
  reportCount Int    @default(0)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  reactions Reaction[]
}

// ============ REACTIONS ============

model Reaction {
  id        String  @id @default(cuid())
  type      String  // "like", "heart", "fire", etc
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  comment Comment @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId, type])
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "comment_reply", "like", "role_change", "system", etc
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ============ ACTIVITY LOGS ============

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // "register", "login", "comment", "role_change", "discord_sync", etc
  details   String?  // JSON string with extra data
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ============ DISCORD CONFIG ============

model DiscordConfig {
  id            String @id @default(cuid())
  botToken      String?
  serverId      String?
  channelId     String?
  webhookUrl    String?
  modRoleId     String?
  adminRoleId   String?
  collabRoleId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ DONATIONS ============

model Donation {
  id        String   @id @default(cuid())
  userId    String?
  nickname  String
  amount    Float
  currency  String   @default("USD")
  platform  String   @default("ko-fi")
  message   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
